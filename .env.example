# Alexandria - Supabase Edge Function Environment Variables
# Copy to .env and fill in your values

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENROUTER_API_KEY=your-openrouter-api-key
MCP_ACCESS_KEY=generate-a-random-secret-here

# AI Models (optional — defaults shown)
EMBEDDING_MODEL=openai/text-embedding-3-small
CLASSIFICATION_MODEL=openai/gpt-4o-mini

# CORS (optional — empty = allow all origins for dev)
# ALLOWED_ORIGINS=https://your-project.supabase.co,https://claude.ai

# Google OAuth (for health-connect/sync.py — optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google OAuth file paths (optional — defaults to importer directory)
# GOOGLE_TOKEN_PATH=/path/to/token.json
# GOOGLE_CLIENT_SECRETS_PATH=/path/to/client_secret.json
